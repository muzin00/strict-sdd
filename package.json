{
  "name": "strict-sdd",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/src/index.js",
  "tspMain": "src/main.tsp",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typespec/compiler": "^1.13.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "tsc && pnpm run build:tsp",
    "watch": "tsc --watch",
    "build:tsp": "tsp compile . --no-emit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "private": true,
  "packageManager": "pnpm@11.6.0"
}