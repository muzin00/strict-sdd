    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typespec/compiler": "^1.13.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.13.0"
  },
  "packageManager": "pnpm@11.6.0"
}
