{
  "name": "strict-sdd",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "ssdd": "dist/src/main.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "ssdd": "node dist/src/main.js",
